@model FormApp.MVC.Models.FormSubmission

@{
    ViewData["Title"] = "Submit Your Details";
}

<div style="max-width: 400px; margin: 60px auto;">
    <h2>Submit Your Details</h2>

    <form asp-action="Index" method="post">

        <div style="margin-bottom: 12px;">
            <label asp-for="FirstName"></label><br />
            <input asp-for="FirstName" style="width: 100%; padding: 8px; margin-top: 4px;" />
            <span asp-validation-for="FirstName" style="color: red;"></span>
        </div>

        <div style="margin-bottom: 12px;">
            <label asp-for="LastName"></label><br />
            <input asp-for="LastName" style="width: 100%; padding: 8px; margin-top: 4px;" />
            <span asp-validation-for="LastName" style="color: red;"></span>
        </div>

        <button type="submit" style="padding: 10px 20px;">Submit</button>

    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}